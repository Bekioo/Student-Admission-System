def calculate_average(subject1, subject2, subject3):
    result = (subject1 + subject2 + subject3) / 3
    return result

def get_grade(average):
    if average >= 90:
        return "A"
    elif average >= 80:
        return "B"
    elif average >= 70:
        return "C"
    elif average >= 60:
        return "D"
    else:
        return "F"
    

average = calculate_average(90, 80, 70) 

grade = get_grade(average)

print("Student result")
print("Average:", average)
print("Grade:", grade)
